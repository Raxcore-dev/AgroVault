generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Alert {
  id                  String      @id @default(cuid())
  alertType           String
  message             String
  severity            String
  isRead              Boolean     @default(false)
  timestamp           DateTime    @default(now())
  storageUnitId       String
  commodityId         String?
  spoilageRisk        String?
  recommendedAction   String?
  recommendedMarketId String?
  Commodity           Commodity?  @relation(fields: [commodityId], references: [id])
  Market              Market?     @relation(fields: [recommendedMarketId], references: [id])
  StorageUnit         StorageUnit @relation(fields: [storageUnitId], references: [id], onDelete: Cascade)
}

model Commodity {
  id                      String      @id @default(cuid())
  commodityName           String
  quantity                Float
  unit                    String      @default("kg")
  dateStored              DateTime    @default(now())
  expectedStorageDuration Int
  createdAt               DateTime    @default(now())
  updatedAt               DateTime              @updatedAt
  storageUnitId           String
  Alert                   Alert[]
  StorageUnit             StorageUnit @relation(fields: [storageUnitId], references: [id], onDelete: Cascade)
}

model CommodityThreshold {
  id             String @id @default(cuid())
  commodityName  String @unique
  minTemp        Float
  maxTemp        Float
  minHumidity    Float
  maxHumidity    Float
  maxStorageDays Int
}

model Conversation {
  id                               String    @id @default(cuid())
  createdAt                        DateTime  @default(now())
  updatedAt                        DateTime              @updatedAt
  buyerId                          String
  farmerId                         String
  productId                        String
  lastMessageAt                    DateTime  @default(now())
  User_Conversation_buyerIdToUser  User      @relation("Conversation_buyerIdToUser", fields: [buyerId], references: [id], onDelete: Cascade)
  User_Conversation_farmerIdToUser User      @relation("Conversation_farmerIdToUser", fields: [farmerId], references: [id], onDelete: Cascade)
  Product                          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  Message                          Message[]

  @@unique([buyerId, farmerId, productId])
  @@index([buyerId])
  @@index([farmerId])
  @@index([lastMessageAt])
  @@index([productId])
}

model Job {
  id             String           @id @default(cuid())
  title          String
  cropType       String
  description    String
  workersNeeded  Int
  payPerDay      Float
  location       String
  latitude       Float
  longitude      Float
  startDate      DateTime
  isOpen         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime              @updatedAt
  farmerId       String
  User           User             @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  JobApplication JobApplication[]
  Message        Message[]

  @@index([cropType])
  @@index([isOpen])
  @@index([location])
}

model JobApplication {
  id        String   @id @default(cuid())
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime              @updatedAt
  jobId     String
  workerId  String
  Job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([jobId, workerId])
}

model Market {
  id                 String   @id @default(cuid())
  marketName         String
  location           String
  commodity          String
  pricePerKg         Float
  latitude           Float
  longitude          Float
  lastUpdated        DateTime @default(now())
  demandLevel        String   @default("medium")
  previousPricePerKg Float?
  priceTrend         String   @default("stable")
  Alert              Alert[]

  @@index([commodity])
  @@index([location])
}

model Message {
  id                            String        @id @default(cuid())
  message                       String
  timestamp                     DateTime      @default(now())
  senderId                      String
  receiverId                    String
  productId                     String?
  jobId                         String?
  conversationId                String?
  isRead                        Boolean       @default(false)
  Conversation                  Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  Job                           Job?          @relation(fields: [jobId], references: [id])
  Product                       Product?      @relation(fields: [productId], references: [id])
  User_Message_receiverIdToUser User          @relation("Message_receiverIdToUser", fields: [receiverId], references: [id])
  User_Message_senderIdToUser   User          @relation("Message_senderIdToUser", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([receiverId])
  @@index([senderId])
  @@index([timestamp])
}

model Product {
  id            String         @id @default(cuid())
  productName   String
  description   String
  price         Float
  quantity      Float
  unit          String         @default("kg")
  productImage  String?
  locationName  String
  latitude      Float
  longitude     Float
  category      String         @default("general")
  isAvailable   Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime              @updatedAt
  farmerId      String
  harvestDate   DateTime?
  storageUnitId String?
  Conversation  Conversation[]
  Message       Message[]
  User          User           @relation(fields: [farmerId], references: [id])
  StorageUnit   StorageUnit?   @relation(fields: [storageUnitId], references: [id])
}

model Sensor {
  id              String           @id @default(cuid())
  name            String
  deviceType      String
  deviceId        String           @unique
  status          String           @default("active")
  batteryLevel    Float?
  firmwareVersion String?
  lastSyncAt      DateTime?
  location        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime              @updatedAt
  storageUnitId   String
  StorageUnit     StorageUnit      @relation(fields: [storageUnitId], references: [id], onDelete: Cascade)
  StorageReading  StorageReading[]

  @@index([deviceId])
  @@index([status])
  @@index([storageUnitId])
}

model StorageReading {
  id            String      @id @default(cuid())
  temperature   Float
  humidity      Float
  status        String      @default("normal")
  recordedAt    DateTime    @default(now())
  storageUnitId String
  sensorId      String?
  Sensor        Sensor?     @relation(fields: [sensorId], references: [id])
  StorageUnit   StorageUnit @relation(fields: [storageUnitId], references: [id], onDelete: Cascade)
}

model StorageUnit {
  id                  String                @id @default(cuid())
  name                String
  location            String
  capacity            Float
  latitude            Float?
  longitude           Float?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  farmerId            String
  Alert               Alert[]
  Commodity           Commodity[]
  Product             Product[]
  Sensor              Sensor[]
  StorageReading      StorageReading[]
  User                User                  @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  WeatherCropAdvisory WeatherCropAdvisory[]
}

model User {
  id                                       String                @id @default(cuid())
  name                                     String
  email                                    String                @unique
  password                                 String
  role                                     String                @default("job_applicant")
  phone                                    String?
  location                                 String?
  createdAt                                DateTime              @default(now())
  updatedAt                                DateTime              @updatedAt
  Conversation_Conversation_buyerIdToUser  Conversation[]        @relation("Conversation_buyerIdToUser")
  Conversation_Conversation_farmerIdToUser Conversation[]        @relation("Conversation_farmerIdToUser")
  Job                                      Job[]
  JobApplication                           JobApplication[]
  Message_Message_receiverIdToUser         Message[]             @relation("Message_receiverIdToUser")
  Message_Message_senderIdToUser           Message[]             @relation("Message_senderIdToUser")
  Product                                  Product[]
  StorageUnit                              StorageUnit[]
  UserLocation                             UserLocation?
  WeatherCropAdvisory                      WeatherCropAdvisory[]
}

model UserLocation {
  id        String   @id @default(cuid())
  userId    String   @unique
  latitude  Float
  longitude Float
  county    String?
  region    String?
  updatedAt DateTime              @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeatherCropAdvisory {
  id                     String      @id @default(cuid())
  storageUnitId          String
  farmerId               String
  currentTemp            Float
  currentHumidity        Float
  forecastedTemp         Float
  forecastedHumidity     Float
  currentSpoilageRisk    Float
  forecastedSpoilageRisk Float
  riskChange             Float
  recommendations        Json
  overallStrategy        String
  rawAiAnalysis          String
  weatherForecastData    Json
  confidenceScore        Float
  createdAt              DateTime    @default(now())
  expiresAt              DateTime
  User                   User        @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  StorageUnit            StorageUnit @relation(fields: [storageUnitId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([storageUnitId, farmerId, createdAt])
}
